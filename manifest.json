{
  "id": "desire-sync",
  "contexts": ["household", "shared_space"],
  "name": "Desire Sync",
  "version": "2.0.2",
  "description": "A private, mutual way for partners to signal interest — only nudges both of you when your signals align.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "couple",
  "tags": [
    "couples"
  ],
  "data_access": {
    "reads": [
      "family.members"
    ],
    "writes": []
  },
  "permissions": {
    "default_audience": "adults",
    "requires_approval": false
  },
  "storage": "db",
  "icon": "💫",
  "nav": {
    "label": "Desire Sync"
  },
  "partner_link": {
    "table": "partner_config",
    "member_column": "member_id",
    "partner_id_column": "partner_id",
    "session_id_column": "session_id",
    "require_role": "adult"
  },
  "row_policies": {
    "partner_config": {
      "kind": "owner_only",
      "member_column": "member_id",
      "adults_bypass": false,
      "endpoint_writes_only": true
    },
    "signals": {
      "kind": "owner_only",
      "member_column": "member_id",
      "adults_bypass": false,
      "endpoint_writes_only": true
    }
  },
  "mutual_signals": {
    "signals_table": "signals",
    "member_column": "member_id",
    "expires_column": "expires_at",
    "partner_table": "partner_config",
    "partner_member_column": "member_id",
    "partner_id_column": "partner_id",
    "partner_session_id_column": "session_id",
    "signal_session_id_column": "session_id",
    "require_reciprocal": true,
    "max_window_hours": 3,
    "notify": {
      "title": "Desire Sync ✨",
      "body": "You're in sync — open the app."
    }
  },
  "kiosk": "never"
}
